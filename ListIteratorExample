package com.nit.set;

import java.util.Arrays;
import java.util.Iterator;
import java.util.List;

public class ListIteratorExample {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
      List<String> language=Arrays.asList("Java","Python","C++","JavaScript");
      
      System.out.println("Using Traditnonal for loop");
      for(int i=0;i<language.size();i++) {
    	  System.out.println(language.get(i));
      }
      
      System.out.println("\nUsing Iterator:");
      Iterator<String> iterator=language.iterator();
      while(iterator.hasNext()) {
    	  System.out.println(iterator.next());
      }
      
      System.out.println("\nUsing forEach():");
      language.forEach(lang->System.out.println(lang));
      
      System.out.println("\nUsing forEach() with Method Refernece:");
      language.forEach(System.out::print);
      
	}

}
