package com.nit.arraytopic;

public class Missingnumber {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
      int []arr= {1,2,3,8};
      int n=5;
      int total= n*(n+1)/2;
      int sum=0;
      
      for(int num:arr) {
    	  sum+=num;
      }
      System.out.println(" "+(total-sum));
	}

}
